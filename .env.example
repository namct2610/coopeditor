# Copy this file to `.env` and edit the values, then run `docker compose up -d`.

# === AUTO-UPDATE (tuỳ chọn) ===
# URL trả về JSON { "sha": "..." } để API biết commit mới nhất bên remote.
# Vd GitHub public repo:
#   https://api.github.com/repos/<owner>/<repo>/commits/main
# UI sẽ hiện badge "Có bản cập nhật" khi local SHA khác remote SHA.
UPDATE_FEED_URL=
# BUILD_SHA + BUILT_AT được scripts/update.sh truyền vào lúc build. Để trống lúc bình thường.
BUILD_SHA=
BUILT_AT=

# === DOMAIN ===
# Tên miền anh trỏ về máy chạy stack (vd. coopeditor.example.com).
# Để "localhost" khi test ngay trên máy mình.
DOMAIN=localhost
PUBLIC_URL=http://localhost

# === POSTGRES ===
POSTGRES_USER=frame
POSTGRES_PASSWORD=frame
POSTGRES_DB=frame_editor

# === EVENT BUS / SCALE-OUT ===
# "pg" = Postgres LISTEN/NOTIFY (mặc định, đủ cho 1 API node).
# "redis-streams" = dùng Redis Streams khi chạy nhiều API node / worker node.
EVENT_BUS_DRIVER=pg
# Có thể đổi nếu muốn tách stream theo môi trường.
EVENT_BUS_STREAM_KEY=frame_editor_events

# === MINIO ===
# Đổi 2 dòng dưới sang giá trị mạnh trước khi mở cho team dùng.
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=frame-proxy
# Multi-region (tuỳ chọn): comma-separated URL của các MinIO khu vực khác.
# Worker upload song song → editor remote ở mỗi region fetch từ replica gần nhất.
# Vd: https://minio-sg.example.com,https://minio-us.example.com
MINIO_REPLICA_ENDPOINTS=

# === HLS CDN (tuỳ chọn, cho editor remote) ===
# Đặt URL public của CDN/front door trước route HLS, ví dụ:
# https://cdn.example.com/api/hls
HLS_CDN_PUBLIC_URL=
# Secret dùng để ký URL segment ngắn hạn để CDN fetch được mà không cần cookie.
HLS_CDN_SIGNING_SECRET=
# TTL của signed segment URL (giây).
HLS_CDN_TOKEN_TTL_SECONDS=300

# === OIDC SSO (tuỳ chọn — song song với DSM) ===
# Bật bằng cách điền cả 4 dòng dưới. Hỗ trợ Google, Keycloak, Auth0, Okta, Azure AD.
# Ví dụ Google: https://accounts.google.com (lấy CLIENT_ID/SECRET từ Google Cloud Console).
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Phải khớp redirect URI đã đăng ký với IdP. Đặt qua Caddy: https://<DOMAIN>/api/auth/oidc/callback
OIDC_REDIRECT_URI=
# (mặc định "openid email profile" — không cần đổi trừ khi IdP yêu cầu)
OIDC_SCOPES=

# === DSM (Synology NAS) ===
# DSM_HOST: URL DSM của anh, có port (5001 cho HTTPS, 5000 cho HTTP).
# Để trống và bật DSM_DEV_LOGIN=1 nếu muốn test mà chưa kết nối NAS thật.
DSM_HOST=https://nas.example.com:5001
DSM_DEV_LOGIN=
# Bật DSM_INSECURE=1 nếu DSM dùng self-signed cert (không có tên miền hợp lệ).
DSM_INSECURE=

# === COOKIE ===
# Bật khi đã có HTTPS (Caddy lo phần cert).
COOKIE_SECURE=1

# === EMAIL NOTIFICATIONS (tuỳ chọn) ===
# Để trống = tắt. Ví dụ với Gmail App Password: smtps://user@gmail.com:APP_PASS@smtp.gmail.com:465
# Tự host: smtp://user:pass@mail.example.com:587
SMTP_URL=
SMTP_FROM=Frame Editor <no-reply@example.com>
# Gom comment lại gửi 1 mail mỗi N phút (giảm spam). 0 = gửi từng cái ngay.
EMAIL_DIGEST_MINUTES=0

# === WEBHOOK NOTIFICATIONS (tuỳ chọn) ===
# Dán incoming webhook URL từ Slack / Discord. Để trống = tắt.
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# === RETENTION (cleanup tự động) ===
# Audit log giữ tối đa N ngày (xóa cứng sau đó).
AUDIT_RETENTION_DAYS=365
# Project archived quá N ngày sẽ bị xóa cứng. Đặt rất cao nếu chưa muốn auto-purge.
PROJECT_PURGE_DAYS=90
# Comment soft-deleted quá N ngày sẽ bị xóa cứng.
COMMENT_PURGE_DAYS=30
# Tần suất quét, phút.
RETENTION_SWEEP_MINUTES=60

# === WORKER ===
# Để trống cho CPU (libx264). "nvenc" cho NVIDIA GPU, "qsv" cho Intel QuickSync.
FFMPEG_HWACCEL=
# Codec ladder: "h264" (default, tương thích nhất), "h265" (tiết kiệm 30-40% bandwidth, cần browser hỗ trợ),
# "mixed" (540p/720p h264, 1080p h265 — cân bằng compat + tiết kiệm bandwidth chi tiết).
FFMPEG_CODEC_LADDER=h264
# Số job transcode chạy song song. CPU thường: 1-2. GPU: 4-8.
WORKER_CONCURRENCY=2
# Khi queue depth vượt ngưỡng này, worker sẽ tự tăng thêm slot xử lý.
WORKER_AUTOSCALE_THRESHOLD=5
# Mỗi "burst" vượt ngưỡng sẽ cộng thêm từng này slot.
WORKER_AUTOSCALE_STEP=1
# Trần concurrency cuối cùng cho một worker process.
WORKER_MAX_CONCURRENCY=3
