#!/bin/sh
# Post-install: lay down runtime config from the wizard answers, initialise
# the SQLite database, and create the Application Portal entry.

set -e

PKG="coopeditor"
TARGET="/var/packages/${PKG}/target"
VAR_DIR="${TARGET}/var"
CONF_DIR="${VAR_DIR}/conf"
RUNTIME_ENV="${CONF_DIR}/runtime.env"
RUNTIME_CONFIG="${CONF_DIR}/runtime-config.json"

mkdir -p "${CONF_DIR}" "${VAR_DIR}/log" "${VAR_DIR}/run" "${VAR_DIR}/proxy"

# Wizard answers are written by DSM into $SYNOPKG_PUBLIC_TEMP/. The wizard
# UIFILE below defines the keys.
WIZARD_VARS="${SYNOPKG_PUBLIC_TEMP:-/tmp}/wizard-vars.sh"
if [ -f "$WIZARD_VARS" ]; then
  . "$WIZARD_VARS"
fi

# Persist as a shell-sourceable env file so start-stop-status can pull values.
{
  echo "# Auto-generated by Coopeditor postinst — edit and restart the package to take effect."
  echo "PORT=${wiz_port:-4000}"
  echo "PUBLIC_URL=${wiz_public_url:-http://localhost:4000}"
  echo "DSM_MOUNT_ROOT=${wiz_dsm_mount_root:-/volume1}"
  echo "DATA_DIR=${VAR_DIR}"
  echo "DATABASE_URL=sqlite:${VAR_DIR}/coopeditor.db"
  echo "OUTPUT_DIR=${VAR_DIR}/proxy"
  echo "RUNTIME_CONFIG_PATH=${RUNTIME_CONFIG}"
} > "$RUNTIME_ENV"

# Seed minimal runtime-config.json so the first boot doesn't fall into the
# "needs setup" wizard.
if [ ! -f "$RUNTIME_CONFIG" ]; then
  cat > "$RUNTIME_CONFIG" <<EOF
{
  "publicUrl": "${wiz_public_url:-http://localhost:4000}",
  "dsmMountRoot": "${wiz_dsm_mount_root:-/volume1}",
  "transcode": { "hwaccel": "auto", "workerConcurrency": 2 }
}
EOF
fi

# Initialise SQLite schema. Idempotent — migrate script handles existing DB.
"${TARGET}/lib/node/bin/node" "${TARGET}/app/apps/api/src/migrate.js" 2>&1 || true

# Make sure the package user can read/write its own state.
chown -R coopeditor:coopeditor "$VAR_DIR" 2>/dev/null || true

exit 0
