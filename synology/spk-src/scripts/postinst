#!/bin/sh
# Minimal postinst — DSM error 276 "failed to acquire postinst worker"
# happens when post-install does too much work in the install transaction.
# Move all heavy work (DB migrate, runtime config seed) into the first
# `start` invocation of start-stop-status, which runs outside the install
# transaction and has no time pressure.
#
# Here we only persist the wizard answers so the start script can read
# them later.

set -e

PKG="coopeditor"
TARGET="/var/packages/${PKG}/target"
VAR_DIR="/var/packages/${PKG}/var"
CONF_DIR="${VAR_DIR}/conf"
RUNTIME_ENV="${CONF_DIR}/runtime.env"

mkdir -p "${CONF_DIR}" "${VAR_DIR}/log" "${VAR_DIR}/run" "${VAR_DIR}/proxy"

# DSM passes wizard answers either as env vars (wiz_*) or via a sourceable
# file at $SYNOPKG_PUBLIC_TEMP/wizard-vars.sh — try the file first since
# env propagation through install workers is unreliable.
WIZARD_VARS="${SYNOPKG_PUBLIC_TEMP:-/tmp}/wizard-vars.sh"
[ -f "$WIZARD_VARS" ] && . "$WIZARD_VARS" || true

cat > "$RUNTIME_ENV" <<EOF
PORT=${wiz_port:-4000}
PUBLIC_URL=${wiz_public_url:-http://localhost:4000}
DSM_MOUNT_ROOT=${wiz_dsm_mount_root:-/volume1}
DATA_DIR=${VAR_DIR}
DATABASE_URL=sqlite:${VAR_DIR}/coopeditor.db
OUTPUT_DIR=${VAR_DIR}/proxy
RUNTIME_CONFIG_PATH=${CONF_DIR}/runtime-config.json
EOF

exit 0
